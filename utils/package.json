{
  "name": "@anjianshi/utils",
  "version": "3.9.0",
  "description": "Common JavaScript Utils",
  "homepage": "https://github.com/anjianshi/js-packages/utils",
  "bugs": {
    "url": "https://github.com/anjianshi/js-packages/issues",
    "email": "anjianshi@gmail.com"
  },
  "license": "MIT",
  "author": "anjianshi <anjianshi@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anjianshi/js-packages.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "directory": "dist"
  },
  "type": "module",
  "scripts": {
    "watch": "npm run clear && tsc --watch",
    "build": "npm run clear && tsc && node publish-prepare.cjs",
    "clear": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "postpublish": "rm dist/package.json",
    "lint": "tsc --noEmit && eslint './src/'"
  },
  "main": "index.js",
  "dependencies": {
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "@anjianshi/presets-eslint-base": "workspace:*",
    "@anjianshi/presets-eslint-node": "workspace:*",
    "@anjianshi/presets-eslint-react": "workspace:*",
    "@anjianshi/presets-eslint-typescript": "workspace:*",
    "@anjianshi/presets-prettier": "workspace:*",
    "@anjianshi/presets-typescript": "workspace:*",
    "@emotion/react": "^11.14.0",
    "@emotion/serialize": "^1.3.3",
    "@emotion/utils": "^1.4.2",
    "@prisma/client": "^7.8.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "chalk": "^5.6.2",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "react": "^19.2.7",
    "redis": "^6.1.0",
    "typescript": "^6.0.3",
    "vconsole": "^3.15.1"
  },
  "prettier": "@anjianshi/presets-prettier/prettierrc"
}
